---
// 文档反馈模块 + 默认页脚。注入到每个文档页底部:「这对我有帮助」点赞 / 点踩 / 反馈,
// 走同源 CF Pages Function /api/doc-feedback → 转发到 RPG Roleplay 的 /api/feedback/anon。
import Default from '@astrojs/starlight/components/Footer.astro';

// Starlight 通过 Astro.props 把路由数据(含 pagination)传给页脚组件。仅真实文档页有
// pagination;404 / splash 没有 → 不渲染反馈块与默认页脚(默认页脚内部解构 pagination,缺失即崩)。
const isDoc = Boolean(Astro.props && Astro.props.pagination);
const isEn = Astro.url.pathname === '/en' || Astro.url.pathname.startsWith('/en/');
const L = isEn
  ? { q: 'Was this page helpful?', yes: 'Helpful', no: 'Not helpful', fb: 'Send feedback', ph: 'Tell us what was unclear, missing, or wrong (you can leave contact info at the end).', send: 'Submit', cancel: 'Cancel', thanks: 'Thanks for your feedback.', fail: 'Could not submit, please try again later.' }
  : { q: '这对我有帮助？', yes: '有帮助', no: '没帮助', fb: '反馈', ph: '告诉我们哪里不清楚、缺失或有误(可在结尾留联系方式)。', send: '提交', cancel: '取消', thanks: '感谢你的反馈。', fail: '提交失败,请稍后再试。' };
---

{isDoc && (<section class="doc-feedback" data-lang={isEn ? 'en' : 'zh-CN'} aria-label={L.q}>
  <span class="df-q">{L.q}</span>
  <div class="df-actions">
    <button type="button" class="df-btn" data-vote="up">{L.yes}</button>
    <button type="button" class="df-btn" data-vote="down">{L.no}</button>
    <button type="button" class="df-btn" data-fb>{L.fb}</button>
  </div>
  <form class="df-form" hidden>
    <textarea class="df-text" rows="3" maxlength="3500" placeholder={L.ph}></textarea>
    <div class="df-row">
      <button type="submit" class="df-btn df-primary">{L.send}</button>
      <button type="button" class="df-btn" data-cancel>{L.cancel}</button>
    </div>
  </form>
  <p class="df-done" hidden></p>
</section>)}

{isDoc && <Default {...Astro.props} />}

<style>
  .doc-feedback {
    margin: 2.5rem 0 1.25rem;
    padding: 1rem 1.1rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.6rem;
    background: var(--sl-color-black);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }
  .df-q { font-weight: 600; font-size: var(--sl-text-sm); color: var(--sl-color-white); }
  .df-actions { display: flex; gap: 0.5rem; }
  .df-btn {
    font: inherit; font-size: var(--sl-text-xs); cursor: pointer;
    padding: 0.35em 0.9em; border-radius: 0.45rem;
    border: 1px solid var(--sl-color-gray-4); background: transparent;
    color: var(--sl-color-gray-1); transition: border-color .15s, color .15s, background .15s;
  }
  .df-btn:hover { border-color: var(--sl-color-accent); color: var(--sl-color-white); }
  .df-primary { border-color: var(--sl-color-accent); color: var(--sl-color-white); }
  .df-form { flex-basis: 100%; display: flex; flex-direction: column; gap: 0.6rem; margin-top: 0.25rem; }
  .df-text {
    width: 100%; font: inherit; font-size: var(--sl-text-sm); color: var(--sl-color-white);
    padding: 0.6rem 0.7rem; border-radius: 0.5rem;
    border: 1px solid var(--sl-color-gray-4); background: var(--sl-color-gray-6); resize: vertical;
  }
  .df-row { display: flex; gap: 0.5rem; }
  .df-done { flex-basis: 100%; margin: 0; font-size: var(--sl-text-sm); color: var(--sl-color-accent-high); }
</style>

<script is:inline define:vars={{ THANKS: L.thanks, FAIL: L.fail }}>
  document.querySelectorAll('.doc-feedback').forEach(function (box) {
    if (box.dataset.wired) return; box.dataset.wired = '1';
    var lang = box.getAttribute('data-lang');
    var actions = box.querySelector('.df-actions');
    var form = box.querySelector('.df-form');
    var text = box.querySelector('.df-text');
    var done = box.querySelector('.df-done');
    function post(payload) {
      return fetch('/api/doc-feedback', {
        method: 'POST', headers: { 'content-type': 'application/json' },
        body: JSON.stringify(Object.assign({ page: location.pathname, lang: lang }, payload)),
      }).then(function (r) { return r.ok; }).catch(function () { return false; });
    }
    function finish(ok) {
      actions.hidden = true; form.hidden = true;
      done.textContent = ok ? THANKS : FAIL; done.hidden = false;
    }
    box.querySelectorAll('[data-vote]').forEach(function (b) {
      b.addEventListener('click', function () { post({ helpful: b.getAttribute('data-vote') === 'up' }).then(finish); });
    });
    box.querySelector('[data-fb]').addEventListener('click', function () { form.hidden = false; text.focus(); });
    box.querySelector('[data-cancel]').addEventListener('click', function () { form.hidden = true; });
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var t = (text.value || '').trim();
      if (!t) { form.hidden = true; return; }
      post({ text: t }).then(finish);
    });
  });
</script>
